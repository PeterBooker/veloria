NAME=Veloria
PORT=9071
ENV=development
VERSION=1.0.0
DATA_DIR=/etc/veloria/data
TEMPLATES_DIR=templates
APP_URL=http://localhost:9071
ACME_EMAIL=
CLOUDFLARE_API_TOKEN=
APP_DEBUG=true
INDEXER_CONCURRENCY=4
SEARCH_CONCURRENCY=4

HTTP_TIMEOUT=2500
HTTP_HANDLER_TIMEOUT=30s
HTTP_READ_TIMEOUT=30s
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_RATE_LIMIT_ENABLED=true
HTTP_LOGGING_ENABLED=true

DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=veloria
DB_USERNAME=veloria
DB_PASSWORD=password
DB_SSLMODE=false
DB_TIMEZONE=UTC
DB_CONNECT_TIMEOUT=5
DB_PING_TIMEOUT=3s
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_IDLE_TIME=10m
DB_CONN_MAX_LIFETIME=1h

MAILPIT_HOST=mailpit
MAILPIT_PORT=1025
MAILPIT_DASHBOARD_PORT=8025

SENTRY_DSN=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=1.0

S3_ENDPOINT=localhost:9000
S3_BUCKET=veloria-searches
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_REGION=us-east-1
S3_ENSURE_BUCKET=false
S3_INIT_TIMEOUT=5s

OAUTH_BASE_URL=https://veloria.ngrok.dev
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
SESSION_SECRET=secret

ASPIRE_CLOUD_API_KEY=
