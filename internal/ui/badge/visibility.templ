package badge

templ Visibility(private bool) {
	if private {
		<span class="inline-flex items-center px-2 py-1 text-xs font-medium rounded-full bg-white/5 text-text-body border border-white/10">Private</span>
	} else {
		<span class="inline-flex items-center px-2 py-1 text-xs font-medium rounded-full bg-green-500/10 text-green-400 border border-green-500/30">Public</span>
	}
}
