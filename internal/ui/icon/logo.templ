package icon

import "strconv"

templ Logo(size int) {
	<svg width={ strconv.Itoa(size) } height={ strconv.Itoa(size) } viewBox="0 0 64 64" fill="none" aria-hidden="true">
		<path d="M30 2L12 24L30 46" class="stroke-neon-cyan" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"></path>
		<path d="M36 18L54 40L36 62" class="stroke-neon-pink" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"></path>
	</svg>
}
