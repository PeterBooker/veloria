package icon

import "strconv"

templ Refresh(size int) {
	<svg width={ strconv.Itoa(size) } height={ strconv.Itoa(size) } fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<polyline points="23 4 23 10 17 10"></polyline>
		<path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
	</svg>
}
