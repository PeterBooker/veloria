package icon

import "strconv"

templ Check(size int) {
	<svg width={ strconv.Itoa(size) } height={ strconv.Itoa(size) } fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<polyline points="20 6 9 17 4 12"></polyline>
	</svg>
}
