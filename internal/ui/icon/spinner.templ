package icon

import "strconv"

templ Spinner(size int) {
	<svg width={ strconv.Itoa(size) } height={ strconv.Itoa(size) } fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="animate-spin">
		<path d="M21 12a9 9 0 1 1-6.219-8.56"></path>
	</svg>
}
